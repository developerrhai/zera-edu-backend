# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database Configuration ───────────────────────────────────────────────────
# Connection URL format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/zera_edu_db

# Fallback individual database variables (if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=zera_edu_db

# ─── Security Configuration ───────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_access_token_key_change_me_in_production
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_change_me_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── CORS Whitelist ───────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000,https://zera-edu-frontend.vercel.app

# ─── Email Transporter (Optional/Mock fallback if empty) ──────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@zeraedu.com
